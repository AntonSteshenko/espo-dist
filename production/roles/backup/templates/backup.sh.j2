#!/bin/bash
set -e

BACKUP_DIR="{{ backup_path }}"
RETENTION_DAYS="{{ backup_retention_days }}"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_FILE="${BACKUP_DIR}/espocrm_${TIMESTAMP}.sql.gz"

echo "[$(date)] Starting backup..."

# Dump database
docker exec espocrm-db mysqldump \
    -u {{ db_user }} \
    -p{{ db_password }} \
    {{ db_name }} | gzip > "${BACKUP_FILE}"

echo "[$(date)] Backup saved to ${BACKUP_FILE}"

# Remove old backups
find "${BACKUP_DIR}" -name "espocrm_*.sql.gz" -mtime +${RETENTION_DAYS} -delete

echo "[$(date)] Cleanup completed. Removed backups older than ${RETENTION_DAYS} days."
